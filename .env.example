# Database Configuration (PostgreSQL)
DATABASE_URL="postgresql://username:password@localhost:5432/chaigpt?schema=public"

# Clerk Authentication Configuration
# Replace these with your Clerk API keys from the Clerk Dashboard
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_placeholder
CLERK_SECRET_KEY=sk_test_placeholder

# Clerk Route Settings
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/

# AI Provider Configuration (OpenRouter)
OPENROUTER_API_KEY=sk-or-v1-placeholder
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Search Tool Integration (Tavily AI)
# Required for Phase 1 Web Search tool calling
TAVILY_API_KEY=tvly-placeholder
